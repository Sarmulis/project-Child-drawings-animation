import cv2
import numpy as np

def enhance_faint_lines(image_path, output_path):
    # 1. Ielādē oriģinālo bērna zīmējumu
    img = cv2.imread(image_path)
    
    if img is None:
        print("Kļūda: Nevar ielādēt attēlu.")
        return

    # 2. Pārveido no BGR (OpenCV standarts) uz LAB krāstelpu
    lab_img = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
    
    # 3. Sadala LAB attēlu atsevišķos kanālos (L, A, B)
    l, a, b = cv2.split(lab_img)
    
    # 4. Izveido CLAHE objektu
    # clipLimit kontrolē, cik agresīvs ir kontrasts (2.0 - 3.0 ir laba bāze zīmuļiem)
    # tileGridSize nosaka bloku lielumu (8x8 ir standarts)
    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))
    
    # 5. Pielieto CLAHE tikai spilgtuma (L) kanālam
    cl = clahe.apply(l)
    
    # 6. Apvieno atpakaļ apstrādāto L kanālu ar oriģinālajiem A un B (krāsu) kanāliem
    merged_lab = cv2.merge((cl, a, b))
    
    # 7. Pārveido atpakaļ uz standarta BGR (RGB) krāstelpu
    final_img = cv2.cvtColor(merged_lab, cv2.COLOR_LAB2BGR)
    
    # 8. Saglabā rezultātu
    cv2.imwrite(output_path, final_img)
    print(f"Attēls ar izceltām līnijām saglabāts: {output_path}")

